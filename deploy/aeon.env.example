# Aeon-V2 environment — copy to ~/aeon-data/aeon.env on the T5810 and edit.
# This file is read by both systemd services. Never commit the real one.

# --- data root (Aeon's OWN memory; lives here, never in the repo/vault) ---
AEON_DATA_DIR=/home/t5810/aeon-data

# --- API ---
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AEON_API_TOKEN=CHANGE_ME
AEON_API_HOST=0.0.0.0
AEON_API_PORT=8900
AEON_WEB_DIST=/home/t5810/Aeon-V2/web/dist

# --- local models (LM Studio on the GTX 1080 FE) ---
AEON_LLM_BASE_URL=http://localhost:1234/v1
AEON_LLM_CHAT_MODEL=qwen3-4b-instruct-2507
AEON_LLM_DEEP_MODEL=qwen3-4b-thinking-2507
AEON_LLM_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# --- extra LLM workers on other mesh machines (comma-separated base URLs) ---
# AEON_MESH_LLM_WORKERS=http://t3610:1234/v1,http://t5810b:1234/v1

# --- Master Vault (READ-ONLY shared context; NOT Aeon's memory) ---
AEON_V1_MASTER_VAULT_PATH=/home/t5810/Master-Vault
AEON_V1_MASTER_VAULT_ENABLED=1

# --- Agent Mesh peer ---
AEON_MESH_HUB=http://127.0.0.1:8787
AEON_MESH_TOKEN=CHANGE_ME
# AEON_MESH_AGENT_ID=aeon@t5810
# Leave tools off over the mesh unless you trust every peer:
# AEON_MESH_ENABLE_TOOLS=1

# --- tool filesystem scope (colon-separated extra read roots) ---
# AEON_TOOLS_FS_ROOTS=/home/t5810/projects:/data
